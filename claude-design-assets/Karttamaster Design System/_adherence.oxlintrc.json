{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/map/**",
              "ui_kits/organizer/**",
              "ui_kits/volunteer/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|iconLeft|iconRight|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, iconLeft, iconRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevation|padding|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: elevation, padding."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:flat|dropdown|modal)$/]",
        "message": "<Card> elevation must be one of 'flat' | 'dropdown' | 'modal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckInSecondaryAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|variant|onClick|key|ref|className|style|children)$/]",
        "message": "<CheckInSecondaryAction> doesn't accept that prop. Declared props: label, variant, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckInSecondaryAction'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:secondary|ghost|danger)$/]",
        "message": "<CheckInSecondaryAction> variant must be one of 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DriveBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:distance|label|direction|near|action|style|key|ref|className|style|children)$/]",
        "message": "<DriveBanner> doesn't accept that prop. Declared props: distance, label, direction, near, action, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|variant|active|size|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: label, variant, active, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|solid|danger)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'solid' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|invalid|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, invalid."
      },
      {
        "selector": "JSXOpeningElement[name.name='MarkerListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:glyph|hue|name|km|status|highlight|trailing|onClick|style|key|ref|className|style|children)$/]",
        "message": "<MarkerListItem> doesn't accept that prop. Declared props: glyph, hue, name, km, status, highlight, trailing, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|pct|detail|height|fill|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, label, pct, detail, height, fill."
      },
      {
        "selector": "JSXOpeningElement[name.name='RouteTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|color|active|hidden|onSelect|onToggleVisibility|style|key|ref|className|style|children)$/]",
        "message": "<RouteTab> doesn't accept that prop. Declared props: label, color, active, hidden, onSelect, onToggleVisibility, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignMarker'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|bearing|status|glyph|size|key|ref|className|style|children)$/]",
        "message": "<SignMarker> doesn't accept that prop. Declared props: type, bearing, status, glyph, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignMarker'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:suunniteltu|asetettu|tarkistettu|keratty|ei_tarpeen)$/]",
        "message": "<SignMarker> status must be one of 'suunniteltu' | 'asetettu' | 'tarkistettu' | 'keratty' | 'ei_tarpeen'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|style|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
